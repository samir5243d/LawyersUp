# --------------------------------------------------------- #
# LOCAL ENVIRONMENT VARIABLES TEMPLATE                      #
# --------------------------------------------------------- #
# Copy this file to .env and fill in your actual secrets.   #
# DO NOT commit your actual .env file to version control.   #
# --------------------------------------------------------- #

# Your Groq API Key (starts with gsk_)
GROQ_API_KEY="your_groq_api_key_here"

# Your Gmail address used for sending emails via SMTP
EMAIL_USER="your_email@gmail.com"

# Your Gmail App Password (NOT your regular account password)
# You need to explicitly generate an "App Password" in Google Account settings
EMAIL_PASS="your_16_character_app_password"
